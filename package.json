{
	"name": "cata",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"start": "node build/index.js",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/ioredis": "^4.28.10",
		"@types/marked": "^5.0.2",
		"@types/node": "^24",
		"better-auth": "~1.4.21",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"postgres": "^3.4.9",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"@auth/core": "^0.41.2",
		"@auth/sveltekit": "^1.11.2",
		"@aws-sdk/client-s3": "^3.1054.0",
		"@aws-sdk/s3-request-presigner": "^3.1054.0",
		"@ffmpeg/ffmpeg": "^0.12.15",
		"@ffmpeg/util": "^0.12.2",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"daisyui": "^5.5.20",
		"gray-matter": "^4.0.3",
		"highlight.js": "^11.11.1",
		"ioredis": "^5.11.0",
		"katex": "^0.16.47",
		"lucide-svelte": "^1.0.1",
		"maplibre-gl": "^5.24.0",
		"marked": "^18.0.3",
		"marked-footnote": "^1.4.0",
		"marked-highlight": "^2.2.4",
		"marked-katex-extension": "^5.1.8",
		"marked-shiki": "^1.2.1",
		"sharp": "^0.34.5",
		"shiki": "^4.1.0",
		"tailwindcss": "^4.3.0",
		"unstorage": "^1.17.5"
	}
}
